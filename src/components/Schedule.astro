---
export interface Props {
  id: string;
  eyebrow: string;
  headline: string;
  rows: { day: string; time: string; class: string; highlight?: boolean }[];
  footer: string;
}

const { id, eyebrow, headline, rows, footer } = Astro.props;
---

<section id={id} class="py-24 md:py-32 bg-cream">
  <div class="max-w-4xl mx-auto px-6">
    <div class="text-center mb-16">
      <p class="uppercase tracking-[0.3em] text-xs text-ocean mb-4">{eyebrow}</p>
      <h2 class="font-display text-4xl md:text-6xl font-medium">{headline}</h2>
    </div>
    <div class="divide-y divide-sand/60 border-t border-b border-sand/60">
      {rows.map((r) => (
        <div class={`grid grid-cols-[1fr_2fr_2fr] items-center py-5 text-sm${r.highlight ? ' bg-sand/10' : ''}`}>
          <div class={`font-display text-xl${r.highlight ? ' text-ocean' : ''}`}>{r.day}</div>
          <div class={r.highlight ? 'text-ocean font-medium' : 'text-dark-slate/60'}>{r.time}</div>
          <div class={r.highlight ? 'text-ocean' : 'text-dark-slate/50'}>{r.class}</div>
        </div>
      ))}
    </div>
    <p class="text-center text-sm text-dark-slate/60 mt-8">{footer}</p>
  </div>
</section>
