---
export interface Props {
  eyebrow: string;
  headline: string;
  headlineItalic: string;
  subheadline: string;
  ctaText: string;
  ctaLink: string;
  backgroundImage: string;
}

const { eyebrow, headline, headlineItalic, subheadline, ctaText, ctaLink, backgroundImage } = Astro.props;
---

<header id="top" class="parallax-section">
  <div class="parallax-bg" style={`background-image: url('${backgroundImage}')`}></div>
  <div class="parallax-overlay"></div>
  <div class="parallax-content text-center px-6 max-w-4xl">
    <p class="uppercase tracking-[0.4em] text-xs md:text-sm mb-6 text-sand">{eyebrow}</p>
    <h1 class="font-display text-6xl md:text-8xl lg:text-9xl font-medium leading-[1.02] mb-8">
      {headline}<br /><span class="italic">{headlineItalic}</span>
    </h1>
    <p class="text-lg md:text-xl max-w-xl mx-auto font-light mb-10">{subheadline}</p>
    <a href={ctaLink} class="inline-block px-10 py-4 bg-cream text-dark-slate rounded-full font-medium hover:bg-sand transition-colors">
      {ctaText}
    </a>
  </div>
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 text-white/80 text-xs uppercase tracking-[0.3em] scroll-indicator z-10">Scroll ↓</div>
</header>
