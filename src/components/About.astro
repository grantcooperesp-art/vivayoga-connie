---
export interface Props {
  id: string;
  eyebrow: string;
  headline: string;
  headlineItalic: string;
  body: string;
  stats: { value: string; label: string }[];
  backgroundImage: string;
}

const { id, eyebrow, headline, headlineItalic, body, stats, backgroundImage } = Astro.props;
---

<section id={id} class="parallax-section" style={`background-image: url('${backgroundImage}')`}>
  <div class="parallax-overlay"></div>
  <div class="parallax-content max-w-4xl mx-auto px-6 text-center">
    <p class="uppercase tracking-[0.3em] text-xs text-sand mb-5">{eyebrow}</p>
    <h2 class="font-display text-4xl md:text-6xl lg:text-7xl font-medium mb-8 leading-[1.05]">
      {headline}<br /><span class="italic">{headlineItalic}</span>
    </h2>
    <p class="text-lg md:text-xl leading-relaxed text-cream/90 max-w-2xl mx-auto">{body}</p>
    <div class="grid grid-cols-3 gap-6 md:gap-12 mt-14 max-w-2xl mx-auto">
      {stats.map((s, i) => (
        <div class={i === 1 ? 'border-x border-cream/20' : ''}>
          <p class="font-display text-4xl md:text-5xl text-sand">{s.value}</p>
          <p class="text-xs md:text-sm text-cream/70 mt-2">{s.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
