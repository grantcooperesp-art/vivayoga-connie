---
export interface Props {
  id: string;
  eyebrow: string;
  headline: string;
  headlineItalic: string;
  subheadline: string;
  whatsapp: { label: string; value: string; href: string };
  email: { label: string; value: string; href: string };
  instagram: { label: string; value: string; href: string };
  whereLabel: string;
  where: { title: string; subtitle: string }[];
  backgroundImage: string;
  formspreeId: string;
}

const {
  id, eyebrow, headline, headlineItalic, subheadline,
  whatsapp, email, instagram, whereLabel, where,
  backgroundImage, formspreeId,
} = Astro.props;
---

<section id={id} class="parallax-section" style={`background-image: url('${backgroundImage}')`}>
  <div
    class="parallax-overlay"
    style="background: linear-gradient(180deg, rgba(44,62,61,0.85) 0%, rgba(44,62,61,0.95) 100%);"
  ></div>
  <div class="parallax-content max-w-5xl mx-auto px-6 w-full py-20">
    <div class="text-center mb-12">
      <p class="uppercase tracking-[0.3em] text-xs text-sand mb-5">{eyebrow}</p>
      <h2 class="font-display text-4xl md:text-6xl font-medium mb-6">{headline}<br /><span class="italic">{headlineItalic}</span></h2>
      <p class="text-lg text-cream/80 max-w-xl mx-auto">{subheadline}</p>
    </div>

    <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-start">
      <form action={`https://formspree.io/f/${formspreeId}`} method="POST" class="space-y-5">
        <div>
          <label class="block text-sm font-medium mb-2 text-cream/80">Name</label>
          <input type="text" name="name" required class="w-full px-4 py-3 bg-cream/10 border border-cream/30 text-cream focus:outline-none focus:border-sand transition-colors" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2 text-cream/80">Email or phone</label>
          <input type="text" name="contact" required class="w-full px-4 py-3 bg-cream/10 border border-cream/30 text-cream focus:outline-none focus:border-sand transition-colors" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2 text-cream/80">Message</label>
          <textarea name="message" rows="4" required class="w-full px-4 py-3 bg-cream/10 border border-cream/30 text-cream focus:outline-none focus:border-sand transition-colors" placeholder="Hi Connie, I'd love to..."></textarea>
        </div>
        <button type="submit" class="w-full py-4 bg-sand text-dark-slate rounded-full font-medium hover:bg-cream transition-colors">Send message</button>
        <p class="text-xs text-cream/50 text-center">Powered by Formspree (free). Connie: sign up at formspree.io and replace the form ID.</p>
      </form>

      <div class="space-y-8">
        <div>
          <p class="text-xs uppercase tracking-[0.3em] text-sand mb-2">{whatsapp.label}</p>
          <a href={whatsapp.href} class="font-display text-2xl md:text-3xl hover:text-sand transition-colors">{whatsapp.value}</a>
        </div>
        <div>
          <p class="text-xs uppercase tracking-[0.3em] text-sand mb-2">{email.label}</p>
          <a href={email.href} class="font-display text-2xl md:text-3xl hover:text-sand transition-colors">{email.value}</a>
        </div>
        <div>
          <p class="text-xs uppercase tracking-[0.3em] text-sand mb-2">{instagram.label}</p>
          <a href={instagram.href} target="_blank" rel="noopener" class="font-display text-2xl md:text-3xl hover:text-sand transition-colors">{instagram.value}</a>
        </div>
        <div>
          <p class="text-xs uppercase tracking-[0.3em] text-sand mb-2">{whereLabel}</p>
          {where.map((w) => (
            <p class="text-base leading-relaxed">
              <strong class="font-medium">{w.title}</strong><br />
              <span class="text-cream/70">{w.subtitle}</span>
            </p>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
