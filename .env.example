# ============================================
# Sanity CMS credentials
# Get these from https://www.sanity.io/manage after creating a free project
# ============================================
PUBLIC_SANITY_PROJECT_ID=your_project_id_here
PUBLIC_SANITY_DATASET=production
PUBLIC_SANITY_API_VERSION=2024-10-01

# Only needed for write operations (seeding). Read uses public dataset.
SANITY_API_WRITE_TOKEN=your_write_token_here

# ============================================
# Site config
# ============================================
PUBLIC_SITE_URL=https://vivayogaconnie.com

# ============================================
# Formspree (for the contact form)
# Connie: sign up free at formspree.io, create a form, paste the form ID
# ============================================
PUBLIC_FORMSPREE_ID=your_formspree_id_here
